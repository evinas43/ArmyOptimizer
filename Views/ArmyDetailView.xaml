<UserControl x:Class="ArmyOptimizer.Views.ArmyDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1622">

    <ScrollViewer>
        <StackPanel Margin="40">

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,30">

                <TextBlock Text="{Binding Army.Name}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,10,0,0">

                    <TextBlock Text="Town Hall "
                               Foreground="#9CA3AF"/>

                    <TextBlock Text="{Binding Army.TownHall}"
                               Foreground="White"
                               FontWeight="Bold"/>

                    <TextBlock Text="  •  "
                               Foreground="#6B7280"/>

                    <TextBlock Text="{Binding Army.CreatedAt,
                                      StringFormat='{}{0:dd MMM yyyy HH:mm}'}"
                               Foreground="#6B7280"/>
                </StackPanel>
            </StackPanel>

            <!-- SUMMARY CARDS -->
            <UniformGrid Columns="4" Margin="0,0,0,40">

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding HeroesCount}"
                                   FontSize="22"
                                   Foreground="White"
                                   FontWeight="Bold"/>
                        <TextBlock Text="HEROES"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">

                    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center">

                        <!-- ICON -->
                        <Image Source="/Images/hero_icon.png"
               Width="26"
               Height="26"
               Margin="0,0,0,10"/>

                        <!-- COUNT -->
                        <TextBlock Text="{Binding HeroesCount}"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"/>

                        <!-- LABEL -->
                        <TextBlock Text="HEROES"
                   Foreground="#9CA3AF"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,5,0,0"/>

                    </StackPanel>

                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SpellsCount}"
                                   FontSize="22"
                                   Foreground="White"
                                   FontWeight="Bold"/>
                        <TextBlock Text="SPELLS"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SiegeCount}"
                                   FontSize="22"
                                   Foreground="White"
                                   FontWeight="Bold"/>
                        <TextBlock Text="SIEGE"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- HEROES SECTION -->
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="HEROES"
                               Foreground="#F59E0B"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding Army.Heroes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A2435"
                                        CornerRadius="8"
                                        Padding="8"
                                        Margin="5">
                                    <TextBlock Text="{Binding}"
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- BACK BUTTON -->
            <Button Content="← Back to Home"
                    Margin="0,40,0,0"
                    Command="{Binding GoBackCommand}"
                    Background="#111C2D"
                    Foreground="White"
                    Padding="10"
                    BorderThickness="0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>