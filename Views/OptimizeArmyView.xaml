
    <UserControl x:Class="ArmyOptimizer.Views.OptimizeArmyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#0B1622">

    <Grid>

        <!-- Back Button -->
        <Button Content=" ← Exit"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FF746C"
                        FontSize="20"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="10"
                        Command="{Binding BackCommand}"/>

        <Button Content=" ← Back"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#cccbca"
                FontSize="20"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10,50,0,0"
                Command="{Binding PreviousStepCommand}"
                Visibility="{Binding ShowBackButton,
                Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- TOWN HALL STEP -->
        <StackPanel Visibility="{Binding IsTownHallStep, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

            <TextBlock Text="Select Your Town Hall"
                                   FontSize="44"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30"/>



            <ItemsControl ItemsSource="{Binding TownHalls}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Button Margin="10"
                    Command="{Binding DataContext.SelectTownHallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding Level}"
                    Background="Transparent"
                    BorderThickness="0">

                            <StackPanel HorizontalAlignment="Center">

                                <!-- IMAGE -->
                                <Border Background="#111C2D"
                            CornerRadius="12"
                            Padding="8">

                                    <Image Source="{Binding Image}"
                               Width="80"
                               Height="80"/>
                                </Border>

                                <!-- TEXT -->
                                <TextBlock Text="{Binding Level, StringFormat=TH{0}}"
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>

                            </StackPanel>

                        </Button>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </StackPanel>

        <!-- ARMY STEP -->
        <Grid Visibility="{Binding IsArmyStep, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- título -->
                <RowDefinition Height="Auto"/>
                <!-- barra -->
                <RowDefinition Height="*"/>
                <!-- scroll -->
                <RowDefinition Height="Auto"/>
                <!-- botón -->
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <TextBlock Grid.Row="0"
               Text="Select Your Army"
               FontSize="24"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,30,0,30"/>

            <!-- PROGRESS -->
            <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,0,0,20">

                <TextBlock Text="Army Camp Space"
                   Foreground="White"
                   Margin="0,0,10,0"/>

                <ProgressBar Width="600"
                     Tag="Army"
                     Style="{StaticResource ArmyProgressBarStyle}"
                     Maximum="{Binding MaxHousing}"
                     Value="{Binding CurrentHousing}"/>

                <TextBlock Text="{Binding CurrentHousing}" Foreground="White" Margin="10,0,0,0"/>
                <TextBlock Text="/" Foreground="White"/>
                <TextBlock Text="{Binding MaxHousing}" Foreground="White"/>
            </StackPanel>

            <!-- SCROLL -->
            <ScrollViewer Grid.Row="2"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                <!-- 🔥 TU STYLE -->
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="10"/>
                        <Setter Property="Background" Value="Transparent"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">

                                        <Border Background="#0f1a2a"
                                        CornerRadius="5"/>

                                        <Track x:Name="PART_Track"
                                       Orientation="Vertical"
                                       IsDirectionReversed="True">

                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                                      Opacity="0"/>
                                            </Track.DecreaseRepeatButton>

                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#F59E0B"
                                                            CornerRadius="5"
                                                            Margin="2"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                                      Opacity="0"/>
                                            </Track.IncreaseRepeatButton>

                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>



                <StackPanel Margin="20">

                    <!-- HEROES -->
                    <TextBlock Text="👑Heroes"
                                                   Foreground="Orange"
                                                   FontSize="18"
                                                   Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding AvailableHeroes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Margin="5"
              Width="150"
              Height="80"
              Foreground="White"
              Background="#111c2b"
              BorderBrush="#1F2A37"
              BorderThickness="1"
              IsChecked="{Binding IsSelected}">

                                    <!-- 👇 NUEVO CONTENIDO -->
                                    <StackPanel HorizontalAlignment="Center">

                                        <Image Source="{Binding Image}"
               Width="40"
               Height="40"
               Margin="0,0,0,5"/>

                                        <TextBlock Text="{Binding Name}"
                   HorizontalAlignment="Center"
                   Foreground="White"/>

                                    </StackPanel>

                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">

                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Background" Value="#111c2b"/>
                                            <Setter Property="BorderBrush" Value="#1F2A37"/>
                                            <Setter Property="BorderThickness" Value="1"/>

                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="6">

                                                            <!-- 👇 ESTO YA FUNCIONA CON EL STACKPANEL -->
                                                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                                                        </Border>

                                                        <ControlTemplate.Triggers>

                                                            <!-- Hover -->
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#3b82f6"/>
                                                            </Trigger>

                                                            <!-- Selected -->
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#F59E0B"/>
                                                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#16283f"/>
                                                            </Trigger>

                                                        </ControlTemplate.Triggers>

                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>

                                        </Style>
                                    </ToggleButton.Style>

                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ELIXIR TROOPS -->
                    <TextBlock Text="💧Elixir Troops"
                                                   Foreground="HotPink"
                                                   FontSize="18"
                                                   Margin="20,20,0,10"/>

                    <ItemsControl ItemsSource="{Binding AvailableElixirTroops}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1F2A37"
                                                                        BorderThickness="0"
                                                                        CornerRadius="10"
                                                                        Padding="10"
                                                                        Margin="5">

                                    <StackPanel>

                                        <Button Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.ToggleTroopCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">

                                            <StackPanel HorizontalAlignment="Center">

                                                <Image Source="{Binding Image}"
                                                   Width="50"
                                                   Height="50"
                                                   Margin="0,0,0,5"/>

                                                <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"/>

                                            </StackPanel>

                                        </Button>

                                        <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding IsSelected,
                                            Converter={StaticResource BoolToVisibilityConverter}}">

                                            <Button Content="-"
                                                                                                Width="25"
                                                                                                Height="25"
                                                                                                FontSize="16"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                Foreground="White"
                                                                                                Command="{Binding DecreaseCommand}"/>

                                            <TextBlock Text="{Binding Quantity}"
                                                                                                   Width="30"
                                                                                                   FontSize="16"
                                                                                                   Foreground="White"
                                                                                                   TextAlignment="Center"
                                                                                                   VerticalAlignment="Center"/>

                                            <Button Content="+"
                                                                                                Width="25"
                                                                                                Height="25"
                                                                                                FontSize="16"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                Foreground="White"
                                                                                                Command="{Binding IncreaseCommand}"/>

                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="💀 Dark Elixir Troops"
                                                   Foreground="Purple"
                                                   FontSize="18"
                                                   Margin="20,20,0,10"/>


                    <ItemsControl ItemsSource="{Binding AvailableDarkTroops}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1F2A37"
                                                                        BorderThickness="0"
                                                                        CornerRadius="10"
                                                                        Padding="10"
                                                                        Margin="5">

                                    <StackPanel>

                                        <Button Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.ToggleTroopCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">

                                            <StackPanel HorizontalAlignment="Center">

                                                <Image Source="{Binding Image}"
                                                   Width="50"
                                                   Height="50"
                                                   Margin="0,0,0,5"/>

                                                <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"/>

                                            </StackPanel>

                                        </Button>

                                        <StackPanel Orientation="Horizontal"
                                                                                            HorizontalAlignment="Center"
                                                                                            Margin="0,8,0,0"
                                                                                            Visibility="{Binding IsSelected,
Converter={StaticResource BoolToVisibilityConverter}}">

                                            <Button Content="-"
                                                                                                Width="25"
                                                                                                Height="25"
                                                                                                FontSize="16"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                Foreground="White"
                                                                                                Command="{Binding DecreaseCommand}"/>

                                            <TextBlock Text="{Binding Quantity}"
                                                                                                   Width="30"
                                                                                                   FontSize="16"
                                                                                                   Foreground="White"
                                                                                                   TextAlignment="Center"
                                                                                                   VerticalAlignment="Center"/>

                                            <Button Content="+"
                                                                                                Width="25"
                                                                                                Height="25"
                                                                                                FontSize="16"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                Foreground="White"
                                                                                                Command="{Binding IncreaseCommand}"/>

                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="⚡Super Troops"
                                                   Foreground="Gold"
                                                   FontSize="18"
                                                   Margin="20,20,0,10"/>

                    <ItemsControl ItemsSource="{Binding AvailableSuperTroops}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1F2A37"
                                                                        BorderThickness="0"
                                                                        CornerRadius="10"
                                                                        Padding="10"
                                                                        Margin="5">

                                    <StackPanel>

                                        <Button Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.ToggleTroopCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">

                                            <StackPanel HorizontalAlignment="Center">

                                                <Image Source="{Binding Image}"
                                                   Width="50"
                                                   Height="50"
                                                   Margin="0,0,0,5"/>

                                                <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"/>

                                            </StackPanel>

                                        </Button>

                                        <StackPanel Orientation="Horizontal"
                                                                                            HorizontalAlignment="Center"
                                                                                            Margin="0,8,0,0"
                                                                                            Visibility="{Binding IsSelected,Converter={StaticResource BoolToVisibilityConverter}}">

                                            <Button Content="-"
                                                                                                Width="25"
                                                                                                Height="25"
                                                                                                FontSize="16"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                Foreground="White"
                                                                                                Command="{Binding DecreaseCommand}"/>

                                            <TextBlock Text="{Binding Quantity}"
                                                                                                   Width="30"
                                                                                                   FontSize="16"
                                                                                                   Foreground="White"
                                                                                                   TextAlignment="Center"
                                                                                                   VerticalAlignment="Center"/>

                                            <Button Content="+"
                                                                                                Width="25"
                                                                                                Height="25"
                                                                                                FontSize="16"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                Foreground="White"
                                                                                                Command="{Binding IncreaseCommand}"/>

                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Next →"
                                Width="150"
                                Height="40"
                                Margin="0,30,0,0"
                                HorizontalAlignment="Center"
                                Background="Orange"
                                Foreground="White"
                                FontWeight="Bold"
                                Command="{Binding NextCommand}"
                                Visibility="{Binding HasSelectedHero, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <!-- SiegeMachines Step -->

        <StackPanel Visibility="{Binding IsSiegeMachineStep, Converter={StaticResource BoolToVisibilityConverter}}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

            <TextBlock Text="Select Your Siege Machines"
               FontSize="24"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,30,0,30"/>

            <StackPanel Orientation="Horizontal"
            Margin="0,0,0,20"
            HorizontalAlignment="Center">

                <TextBlock Text="SiegeMachines Space"
                   Foreground="White"
                   Margin="0,0,10,0"/>

                <ProgressBar Width="600"
                     Tag="SiegeMachines"
                     Style="{StaticResource ArmyProgressBarStyle}"
                     Maximum="{Binding MaxSiegeMachineHousing}"
                     Value="{Binding CurrentSiegeMachineHousing}"/>

                <TextBlock Text="{Binding CurrentSiegeMachineHousing}"
                   Foreground="White"
                   Margin="10,0,0,0"/>

                <TextBlock Text="/"
       Foreground="White"/>

                <TextBlock Text="{Binding MaxSiegeMachineHousing}"
       Foreground="White"/>

            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="20">

                    <!-- SiegeMachines -->
                    <TextBlock Text="💧SiegeMachines"
                       Foreground="HotPink"
                       FontSize="18"
                       Margin="20,20,0,10"/>

                    <ItemsControl ItemsSource="{Binding AvailableSiegeMachines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1F2A37"
                    BorderThickness="0"
                    CornerRadius="10"
                    Padding="10"
                    Margin="5">

                                    <StackPanel>



                                        <Button Background="Transparent"
                                         BorderThickness="0"
                                         Command="{Binding DataContext.ToggleSiegeMachinesCommand,
                                         RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                         CommandParameter="{Binding}">

                                        <StackPanel HorizontalAlignment="Center">

                                            <Image Source="{Binding Image}"
                                                Width="50"
                                                Height="50"
                                                Margin="0,0,0,5"/>

                                            <TextBlock Text="{Binding Name}"
                                                Foreground="White"
                                                HorizontalAlignment="Center"/>

                                        </StackPanel>

                                        </Button>
                                        <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Visibility="{Binding IsSelected,
                                Converter={StaticResource BoolToVisibilityConverter}}">

                                            <Button Content="-"
                                Width="25"
                                Height="25"
                                FontSize="16"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Command="{Binding DecreaseCommand}"/>

                                            <TextBlock Text="{Binding Quantity}"
                                   Width="30"
                                   FontSize="16"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"/>

                                            <Button Content="+"
                                Width="25"
                                Height="25"
                                FontSize="16"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Command="{Binding IncreaseCommand}"/>

                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
            <Button Content="Next →"
                  Width="150"
                  Height="40"
                  Margin="0,30,0,0"
                  HorizontalAlignment="Center"
                  Background="Orange"
                  Foreground="White"
                  FontWeight="Bold"
                  Command="{Binding NextCommand}"
                  Visibility="{Binding HasSelectedSiegeMachine, Converter={StaticResource BoolToVisibilityConverter}}"/>

        </StackPanel>

        <!-- SPELL STEP -->
        <StackPanel Visibility="{Binding IsSpellStep, Converter={StaticResource BoolToVisibilityConverter}}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

            <TextBlock Text="Select Your Spells"
               FontSize="24"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="0,30,0,30"/>

            <StackPanel Orientation="Horizontal"
                Margin="0,0,0,20"
                HorizontalAlignment="Center">

                <TextBlock Text="Spell Space"
                   Foreground="White"
                   Margin="0,0,10,0"/>

                <ProgressBar Width="600"
                     Tag="Spells"
                     Style="{StaticResource ArmyProgressBarStyle}"
                     Maximum="{Binding MaxSpellHousing}"
                     Value="{Binding CurrentSpellHousing}"/>

                <TextBlock Text="{Binding CurrentSpellHousing}"
                   Foreground="White"
                   Margin="10,0,0,0"/>

                <TextBlock Text="/"
                   Foreground="White"/>

                <TextBlock Text="{Binding MaxSpellHousing}"
                   Foreground="White"/>

            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="20">

                    <!-- ELIXIR SPELLS -->
                    <TextBlock Text="💧Elixir Spells"
                       Foreground="HotPink"
                       FontSize="18"
                       Margin="20,20,0,10"/>

                    <ItemsControl ItemsSource="{Binding AvailableElixirSpells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1F2A37"
                                BorderThickness="0"
                                CornerRadius="10"
                                Padding="10"
                                Margin="5">

                                    <StackPanel>
                                        <Button Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.ToggleSpellCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">

                                        <StackPanel HorizontalAlignment="Center">

                                            <Image Source="{Binding Image}"
                                                   Width="50"
                                                   Height="50"
                                                   Margin="0,0,0,5"/>

                                            <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"/>

                                        </StackPanel>

                                        </Button>

                                        <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding IsSelected,
                                            Converter={StaticResource BoolToVisibilityConverter}}">

                                            <Button Content="-"
                                            Width="25"
                                            Height="25"
                                            FontSize="16"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="White"
                                            Command="{Binding DecreaseCommand}"/>

                                            <TextBlock Text="{Binding Quantity}"
                                               Width="30"
                                               FontSize="16"
                                               Foreground="White"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"/>

                                            <Button Content="+"
                                            Width="25"
                                            Height="25"
                                            FontSize="16"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="White"
                                            Command="{Binding IncreaseCommand}"/>

                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>


                    <!-- DARK SPELLS -->
                    <TextBlock Text="💀 Dark Elixir Spells"
                       Foreground="Purple"
                       FontSize="18"
                       Margin="20,20,0,10"/>

                    <ItemsControl ItemsSource="{Binding AvailableDarkSpells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1F2A37"
                                BorderThickness="0"
                                CornerRadius="10"
                                Padding="10"
                                Margin="5">

                                    <StackPanel>
                                        <Button Background="Transparent"
                                             BorderThickness="0"
                                             Command="{Binding DataContext.ToggleSpellCommand,
                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                             CommandParameter="{Binding}">

                                            <StackPanel HorizontalAlignment="Center">

                                                <Image Source="{Binding Image}"
                                                    Width="50"
                                                    Height="50"
                                                    Margin="0,0,0,5"/>

                                                <TextBlock Text="{Binding Name}"
                                                    Foreground="White"
                                                    HorizontalAlignment="Center"/>      

                                            </StackPanel>

                                        </Button>

                                        <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding IsSelected,
                                            Converter={StaticResource BoolToVisibilityConverter}}">

                                            <Button Content="-"
                                            Width="25"
                                            Height="25"
                                            FontSize="16"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="White"
                                            Command="{Binding DecreaseCommand}"/>

                                            <TextBlock Text="{Binding Quantity}"
                                               Width="30"
                                               FontSize="16"
                                               Foreground="White"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"/>

                                            <Button Content="+"
                                            Width="25"
                                            Height="25"
                                            FontSize="16"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="White"
                                            Command="{Binding IncreaseCommand}"/>

                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

            </ScrollViewer>
            <Button Content="Watch summary →"
                     Width="150"
                     Height="40"
                     Margin="0,30,0,0"
                     HorizontalAlignment="Center"
                     Background="Orange"
                     Foreground="White"
                     FontWeight="Bold"
                     Command="{Binding NextCommand}"
                     Visibility="{Binding HasSelectedSpell, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <Grid Visibility="{Binding IsSummaryStep, Converter={StaticResource BoolToVisibilityConverter}}"
      Margin="30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20">
                <TextBlock Text="Army Summary"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"/>

                <TextBlock Text="Your optimized army"
                   FontSize="14"
                   Foreground="#9CA3AF"
                   HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- INFO BAR -->
            <Border Grid.Row="1"
            Background="#111c2b"
            CornerRadius="12"
            Padding="15"
            Margin="0,20">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <TextBlock Text="{Binding TownHallLevel, StringFormat=🏠 TH{0}}"
                       Foreground="Orange"
                       Margin="20,0"/>

                    <TextBlock Text="{Binding CurrentHousing}" Foreground="Green"/>
                    <TextBlock Text="/" Foreground="Green"/>
                    <TextBlock Text="{Binding MaxHousing}" Foreground="Green"/>
                    <TextBlock Text="⚔️" Foreground="Green" Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding CurrentSpellHousing}" Foreground="#b55385"/>
                    <TextBlock Text="/" Foreground="#b55385"/>
                    <TextBlock Text="{Binding MaxSpellHousing}" Foreground="#b55385"/>
                    <TextBlock Text="🧪" Foreground="#b55385" Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding CurrentSiegeMachineHousing}" Foreground="#c23b22"/>
                    <TextBlock Text="/" Foreground="#c23b22"/>
                    <TextBlock Text="{Binding MaxSiegeMachineHousing}" Foreground="#c23b22"/>
                    <TextBlock Text="🏰" Foreground="#c23b22"/>

                </StackPanel>
            </Border>

            <!-- SCROLL CONTENT -->
            <ScrollViewer Grid.Row="2"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <!-- HEROES -->
                    <Border Grid.Row="0" Grid.Column="0"
                    Background="#111c2b"
                    CornerRadius="12"
                    Padding="15"
                    Margin="10">

                        <StackPanel>
                            <TextBlock Text="👑 Heroes"
                               Foreground="Orange"
                               FontSize="18"
                               Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding SelectedHeroes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="3">
                                            <TextBlock Text="{Binding Name}" Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- TROOPS -->
                    <Border Grid.Row="0" Grid.Column="1"
                    Background="#111c2b"
                    CornerRadius="12"
                    Padding="15"
                    Margin="10">

                        <StackPanel>
                            <TextBlock Text="⚔ Troops"
                               Foreground="HotPink"
                               FontSize="18"
                               Margin="0,0,0,10"/>

                            <!-- ELIXIR -->
                            <ItemsControl ItemsSource="{Binding SelectedElixirTroops}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="3">
                                            <TextBlock Foreground="White">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text="x "/>
                                        <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- DARK -->
                            <ItemsControl ItemsSource="{Binding SelectedDarkTroops}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="3">
                                            <TextBlock Foreground="White">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text="x "/>
                                        <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- SUPER -->
                            <ItemsControl ItemsSource="{Binding SelectedSuperTroops}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="3">
                                            <TextBlock Foreground="White">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text="x "/>
                                        <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- SPELLS  -->
                    <Border Grid.Row="1" Grid.Column="0"
                    Background="#111c2b"
                    CornerRadius="12"
                    Padding="15"
                    Margin="10">

                        <StackPanel>
                            <TextBlock Text="🧪 Spells"
                               Foreground="GreenYellow"
                               FontSize="18"
                               Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding SelectedElixirSpells}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="3">
                                            <TextBlock Foreground="White">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text="x "/>
                                        <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding SelectedDarkSpells}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="3">
                                            <TextBlock Foreground="White">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text="x "/>
                                        <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- SIEGE  -->
                    <Border Grid.Row="1" Grid.Column="1"
                    Background="#111c2b"
                    CornerRadius="12"
                    Padding="15"
                    Margin="10">

                        <StackPanel>
                            <TextBlock Text="🏰 Siege Machines"
                               Foreground="Red"
                               FontSize="18"
                               Margin="0,0,0,10"/>

                            <ItemsControl ItemsSource="{Binding SelectedSiegeMachines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                        CornerRadius="6"
                                        Padding="6"
                                        Margin="3">
                                            <TextBlock Foreground="White">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text="x "/>
                                        <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                </Grid>
            </ScrollViewer>

            <!-- BUTTON -->
            <Button Content="Optimize! →"
            Grid.Row="3"
            Width="150"
            Height="40"
            Margin="0,30,0,0"
            HorizontalAlignment="Center"
            Background="Orange"
            Foreground="White"
            FontWeight="Bold"
            Command="{Binding OptimizeCommand}"/>

        </Grid>


        <!-- Optimized army step -->

        <Grid Visibility="{Binding IsOptimizedStep, Converter={StaticResource BoolToVisibilityConverter}}"
      Margin="30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20">

                <TextBlock Text="Optimized Army"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"/>

                <TextBlock Text="Optimized Equipments for your Team💪"
                   FontSize="14"
                   Foreground="#9CA3AF"
                   HorizontalAlignment="Center"/>

            </StackPanel>


            <!-- SCROLLABLE CONTENT -->
            <ScrollViewer Grid.Row="1"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="10"/>
                        <Setter Property="Background" Value="Transparent"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">

                                    <Grid Background="Transparent">

                                        <!-- Track -->
                                        <Border Background="#0f1a2a"
                                    CornerRadius="5"/>

                                        <Track x:Name="PART_Track"
                                   Orientation="Vertical"
                                   IsDirectionReversed="True">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"/>
                                            </Track.DecreaseRepeatButton>

                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#F59E0B"
                                                        CornerRadius="5"
                                                        Margin="2"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"/>
                                            </Track.IncreaseRepeatButton>

                                        </Track>

                                    </Grid>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>

                <StackPanel>

                    <!-- ARMY RESULT -->
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>


                        <!-- HEROES -->
                        <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="#111c2b"
                        CornerRadius="12"
                        Padding="15"
                        Margin="10">

                            <StackPanel>

                                <TextBlock Text="👑 Heroes"
                                   Foreground="Orange"
                                   FontSize="18"
                                   Margin="0,0,0,10"/>

                                <ItemsControl ItemsSource="{Binding OptimizedHeroLoadouts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1f2937"
            CornerRadius="6"
            Padding="8"
            Margin="4">

                                                <StackPanel>

                                                    <!-- HERO HEADER -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">

                                                        <!-- HERO IMAGE -->
                                                        <Image Source="{Binding Image}"
                       Width="45"
                       Height="45"
                       Margin="0,0,10,0"/>

                                                        <TextBlock Text="{Binding HeroName}"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                                                    </StackPanel>

                                                    <!-- EQUIPMENT -->
                                                    <ItemsControl ItemsSource="{Binding Equipment}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding StringFormat='• {0}'}"
                                                                   Foreground="#9CA3AF"
                                                                   FontSize="12"
                                                                   Margin="5,0,0,0"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- PET -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                                                        <Image Source="{Binding PetImage}"
                       Width="25"
                       Height="25"
                       Margin="0,0,5,0"/>

                                                        <TextBlock Text="{Binding PetName}"
                           Foreground="#F59E0B"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                                                    </StackPanel>

                                                </StackPanel>

                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>

                        </Border>


                        <!-- TROOPS -->
                        <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="#111c2b"
                        CornerRadius="12"
                        Padding="15"
                        Margin="10">

                            <StackPanel>

                                <TextBlock Text="⚔ Troops"
                                   Foreground="HotPink"
                                   FontSize="18"
                                   Margin="0,0,0,10"/>

                                <ItemsControl ItemsSource="{Binding OptimizedTroops}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1f2937"
            CornerRadius="6"
            Padding="6"
            Margin="3">

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                                    <!-- IMAGE -->
                                                    <Image Source="{Binding Image}"
                   Width="40"
                   Height="40"
                   Margin="0,0,10,0"/>

                                                    <!-- TEXT -->
                                                    <TextBlock Foreground="White" VerticalAlignment="Center">
                <Run Text="{Binding Quantity}"/>
                <Run Text="x "/>
                <Run Text="{Binding Name}"/>
                                                    </TextBlock>

                                                </StackPanel>

                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>

                        </Border>


                        <!-- SPELLS -->
                        <Border Grid.Row="1"
                        Grid.Column="0"
                        Background="#111c2b"
                        CornerRadius="12"
                        Padding="15"
                        Margin="10">

                            <StackPanel>

                                <TextBlock Text="🧪 Spells"
                                   Foreground="GreenYellow"
                                   FontSize="18"
                                   Margin="0,0,0,10"/>

                                <ItemsControl ItemsSource="{Binding OptimizedSpells}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1f2937"
            CornerRadius="6"
            Padding="6"
            Margin="3">

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                                    <!-- IMAGE -->
                                                    <Image Source="{Binding Image}"
                   Width="40"
                   Height="40"
                   Margin="0,0,10,0"/>

                                                    <!-- TEXT -->
                                                    <TextBlock Foreground="White" VerticalAlignment="Center">
                <Run Text="{Binding Quantity}"/>
                <Run Text="x "/>
                <Run Text="{Binding Name}"/>
                                                    </TextBlock>

                                                </StackPanel>

                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>

                        </Border>


                        <!-- SIEGE -->
                        <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="#111c2b"
                        CornerRadius="12"
                        Padding="15"
                        Margin="10">

                            <StackPanel>

                                <TextBlock Text="🏰 Siege Machine"
                                   Foreground="Red"
                                   FontSize="18"
                                   Margin="0,0,0,10"/>

                                <ItemsControl ItemsSource="{Binding OptimizedSiegeMachines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1f2937"
            CornerRadius="6"
            Padding="6"
            Margin="3">

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                                    <!-- IMAGE -->
                                                    <Image Source="{Binding Image}"
                   Width="40"
                   Height="40"
                   Margin="0,0,10,0"/>

                                                    <!-- TEXT -->
                                                    <TextBlock Foreground="White" VerticalAlignment="Center">
                <Run Text="{Binding Quantity}"/>
                <Run Text="x "/>
                <Run Text="{Binding Name}"/>
                                                    </TextBlock>

                                                </StackPanel>

                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>


                    <!-- AI ADVICE -->
                    <Border Background="#111c2b"
                    CornerRadius="12"
                    Padding="20"
                    Margin="10">

                        <StackPanel>

                            <TextBlock Text="💡Advice"
                               FontSize="18"
                               Foreground="#F59E0B"
                               Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding AiAdvice}"
                               TextWrapping="Wrap"
                               Foreground="White"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#111c2b"
                    CornerRadius="12"
                    Padding="20"
                    Margin="10">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10" >


                            <Button Content="Discard Army 🗑️" Background="#FA6868" FontWeight="Bold" Width="150" Height="40"
                            Margin="0,30,20,0"  HorizontalAlignment="Center" Command="{Binding BackCommand}"/>

                            <Button Content="Save Army📥"
                             Width="150"
                             Height="40"
                             Margin="0,30,0,0"
                             HorizontalAlignment="Center"
                             Background="Green"
                             Foreground="White"
                             FontWeight="Bold"
                             Command="{Binding SaveArmyCommand}"
                            />
                        </StackPanel>
                        
                    </Border>

                </StackPanel>

            </ScrollViewer>

        </Grid>


        <!--Custom Spinner -->
        
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
            Width="120" Height="120">

            <TextBlock Text="⚔️"
               FontSize="80"
               HorizontalAlignment="Center"
               VerticalAlignment="Center">  

                <TextBlock.Foreground>
                    <LinearGradientBrush x:Name="SwordGradient"
                         StartPoint="0,0"
                         EndPoint="1,0">

                        <!-- base sword -->
                        <GradientStop Color="#101010" Offset="0"/>
                        <GradientStop Color="#101010" Offset="0.30"/>

                        <!-- glow start -->
                        <GradientStop x:Name="GlowStart" Color="#F59E0B" Offset="0.40"/>

                        <!-- strong bright orange -->
                        <GradientStop x:Name="GlowCenter1" Color="#F59E0B" Offset="0.48"/>

                        <!-- strongest highlight -->
                        <GradientStop x:Name="GlowCenter2" Color="#F59E0B" Offset="0.50"/>

                        <!-- fade out -->
                        <GradientStop x:Name="GlowCenter3" Color="#e39005" Offset="0.52"/>

                        <GradientStop x:Name="GlowEnd" Color="#b87300" Offset="0.60"/>

                        <GradientStop Color="#101010" Offset="0.70"/>
                        <GradientStop Color="#101010" Offset="1"/>

                    </LinearGradientBrush>
                </TextBlock.Foreground>

                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">

                                <DoubleAnimation Storyboard.TargetName="GlowStart"
                                 Storyboard.TargetProperty="Offset"
                                 From="-0.32"
                                 To="1.54"
                                 Duration="0:0:2.4"/>

                                <DoubleAnimation Storyboard.TargetName="GlowCenter1"
                                 Storyboard.TargetProperty="Offset"
                                 From="-0.32"
                                 To="1.56"
                                 Duration="0:0:2.4"/>

                                <DoubleAnimation Storyboard.TargetName="GlowCenter2"
                                 Storyboard.TargetProperty="Offset"
                                 From="-0.32"
                                 To="1.58"
                                 Duration="0:0:2.4"/>

                                <DoubleAnimation Storyboard.TargetName="GlowCenter3"
                                 Storyboard.TargetProperty="Offset"
                                 From="-0.32"
                                 To="1.59"
                                 Duration="0:0:2.4"/>

                                <DoubleAnimation Storyboard.TargetName="GlowEnd"
                                 Storyboard.TargetProperty="Offset"
                                 From="-0.32"
                                 To="1.63"
                                 Duration="0:0:2.4"/>

                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>

            </TextBlock>
            
        </Grid>
        
        <Grid Visibility="{Binding IsHardLoading, Converter={StaticResource BoolToVisibilityConverter}}"
          Background="#80000000"
          Panel.ZIndex="9999">

            <!-- Blur/Glass -->
            <Border Background="#660B1622"/>

            <!-- Spinner -->
            <Grid Width="140"
          Height="140"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">

                <Border Background="#111c2b"
                CornerRadius="20"
                Opacity="0.95"/>

                <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <TextBlock Text="⚔️"
                       FontSize="70"
                       HorizontalAlignment="Center">

                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,0">

                                <GradientStop Color="#101010" Offset="0"/>
                                <GradientStop Color="#101010" Offset="0.30"/>

                                <GradientStop x:Name="HardGlowStart"
                                      Color="#F59E0B"
                                      Offset="0.40"/>

                                <GradientStop x:Name="HardGlowCenter"
                                      Color="#F59E0B"
                                      Offset="0.50"/>

                                <GradientStop x:Name="HardGlowEnd"
                                      Color="#101010"
                                      Offset="0.70"/>

                            </LinearGradientBrush>
                        </TextBlock.Foreground>

                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">

                                        <DoubleAnimation Storyboard.TargetName="HardGlowStart"
                                                 Storyboard.TargetProperty="Offset"
                                                 From="-0.3"
                                                 To="1.3"
                                                 Duration="0:0:1.8"/>

                                        <DoubleAnimation Storyboard.TargetName="HardGlowCenter"
                                                 Storyboard.TargetProperty="Offset"
                                                 From="-0.2"
                                                 To="1.4"
                                                 Duration="0:0:1.8"/>

                                        <DoubleAnimation Storyboard.TargetName="HardGlowEnd"
                                                 Storyboard.TargetProperty="Offset"
                                                 From="0"
                                                 To="1.6"
                                                 Duration="0:0:1.8"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>

                    </TextBlock>

                    <TextBlock Text="Optimizing Army..."
                       Foreground="White"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>

                </StackPanel>

            </Grid>

        </Grid>
    </Grid>
</UserControl>