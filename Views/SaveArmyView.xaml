<UserControl x:Class="ArmyOptimizer.Views.SaveArmyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1622">

    <Grid Margin="30">



        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <Grid Grid.Row="0">

            <Button Content=" ← Back"
            Background="Transparent"
            BorderThickness="0"
            Foreground="#cccbca"
            FontSize="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10"
            Command="{Binding BackCommand}"/>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,45">

                <TextBlock Text="Save Your Army"
               FontSize="36"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"/>


                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Save your army for later uses "
               FontSize="16"
               Foreground="#9CA3AF"
               HorizontalAlignment="Center"
               Margin="15,5,0,0"/>
                    <TextBlock Text="⚔️" Foreground="Orange" FontSize="16" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                </StackPanel>



            </StackPanel>

        </Grid>

        <ScrollViewer Grid.Row="1"
  VerticalScrollBarVisibility="Auto"
  HorizontalScrollBarVisibility="Disabled">

            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Background" Value="Transparent"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">

                                <Grid Background="Transparent">

                                    <!-- Track -->
                                    <Border Background="#0f1a2a"
                        CornerRadius="5"/>

                                    <Track x:Name="PART_Track"
                       Orientation="Vertical"
                       IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand"
                                      Opacity="0"/>
                                        </Track.DecreaseRepeatButton>

                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#F59E0B"
                                            CornerRadius="5"
                                            Margin="2"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>

                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand"
                                      Opacity="0"/>
                                        </Track.IncreaseRepeatButton>

                                    </Track>

                                </Grid>

                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ScrollViewer.Resources>

            <StackPanel>

                <!-- INPUT -->
                <Border Background="#111c2b"
                        CornerRadius="16"
                        Padding="25"
                        Margin="10">

                    <StackPanel>

                        <TextBlock Text="Army Name"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBox Text="{Binding Name}"
                                 Height="40"
                                 FontSize="15"
                                 Background="#1f2937"
                                 Foreground="White"
                                 BorderBrush="#374151"
                                 Padding="10"
                                 Margin="0,0,0,20"/>

                        <TextBlock Text="Description"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBox Text="{Binding Description}"
                                 Height="100"
                                 FontSize="14"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="#1f2937"
                                 Foreground="White"
                                 BorderBrush="#374151"
                                 Padding="10"/>

                    </StackPanel>
                </Border>

                <!-- SUMMARY -->
                <Grid Margin="0,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    

                    <!-- HEROES -->
                    <Border Grid.Row="0" Grid.Column="0"
                            Background="#111c2b"
                            CornerRadius="16"
                            Padding="20"
                            Margin="10">

                        <StackPanel>

                            <TextBlock Text="👑 Heroes"
                                       Foreground="Orange"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding ArmyData.heroLoadouts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                                CornerRadius="10"
                                                Padding="10"
                                                Margin="4">

                                            <StackPanel>

                                                <TextBlock Text="{Binding HeroName}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,5"
                                                           Foreground="White"/>

                                                <ItemsControl ItemsSource="{Binding Equipment}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       Foreground="#9CA3AF"
                                                                       FontSize="13"
                                                                       FontWeight="Bold"
                                                                       Margin="8,0,0,0"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding PetName, StringFormat=🐾 {0}}"
                                                           Foreground="#F59E0B"
                                                           FontSize="13"
                                                           Margin="0,5,0,0"/>

                                            </StackPanel>

                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- TROOPS -->
                    <Border Grid.Row="0" Grid.Column="1"
                            Background="#111c2b"
                            CornerRadius="16"
                            Padding="20"
                            Margin="10">

                        <StackPanel>

                            <TextBlock Text="⚔ Troops"
                                       Foreground="HotPink"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding ArmyData.troops}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                                CornerRadius="8"
                                                Padding="6"
                                                Margin="3">
                                            <TextBlock Foreground="White" FontSize="14">
                                                <Run Text="{Binding Quantity}"/>
                                                <Run Text="x "/>
                                                <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- SPELLS -->
                    <Border Grid.Row="1" Grid.Column="0"
                            Background="#111c2b"
                            CornerRadius="16"
                            Padding="20"
                            Margin="10">

                        <StackPanel>

                            <TextBlock Text="🧪 Spells"
                                       Foreground="GreenYellow"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding ArmyData.spells}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1f2937"
                                                CornerRadius="8"
                                                Padding="6"
                                                Margin="3">
                                            <TextBlock Foreground="White" FontSize="14">
                                                <Run Text="{Binding Quantity}"/>
                                                <Run Text="x "/>
                                                <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <!-- SIEGE -->
                    <Border Grid.Row="1" Grid.Column="1"
                            Background="#111c2b"
                            CornerRadius="16"
                            Padding="20"
                            Margin="10">

                        <StackPanel>

                            <TextBlock Text="🏰 Siege Machine"
                                       Foreground="Red"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,0,0,12"/>


                            <ItemsControl ItemsSource="{Binding ArmyData.siegeMachines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border Background="#1f2937"
                                                    CornerRadius="8"
                                                    Padding="6"
                                                    Margin="3">

                                            <TextBlock Foreground="White" FontSize="14">
                                                    <Run Text="{Binding Quantity}"/>
                                                    <Run Text="x "/>
                                                    <Run Text="{Binding Name}"/>
                                            </TextBlock>

                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <!-- AI ADVICE -->
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#111c2b"
                    CornerRadius="12"
                    Padding="20"
                    Margin="10">

                        <StackPanel>

                            <TextBlock Text="💡Advice"
                               FontSize="18"
                               Foreground="#F59E0B"
                               Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding ArmyData.aiNotes}"
                               TextWrapping="Wrap"
                               Foreground="White"/> 

                        </StackPanel>

                    </Border>



                </Grid>

                <!-- SAVE -->
                <Button Content="💾 Save Army"
                        Height="50"
                        Width="220"
                        HorizontalAlignment="Center"
                        Background="Green"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White"
                        Margin="20"
                        Command="{Binding SaveCommand}"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</UserControl>