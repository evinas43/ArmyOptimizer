<Application x:Class="ArmyOptimizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ArmyOptimizer"
             xmlns:views="clr-namespace:ArmyOptimizer.Views"
             xmlns:vm="clr-namespace:ArmyOptimizer.ViewModels"
             StartupUri="MainWindow.xaml">
    
    <Application.Resources>

        <DataTemplate DataType="{x:Type vm:LoginVM}">
            <views:LoginView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegisterVM}">
            <views:RegisterView/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:HomeVM}">
            <views:HomeView/>
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:ArmyDetailVM}">
            <views:ArmyDetailView/>
        </DataTemplate>
        
        
        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111C2D"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111C2D"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

    </Application.Resources>
   
</Application>
